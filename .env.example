# AWS Credentials
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# S3 Configuration (free tier: 5GB storage, 20K GET, 2K PUT/month)
S3_BUCKET_NAME=my-pdf-qa-bucket

# Bedrock Configuration (pay-per-use, Haiku is cheapest)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Embeddings: FREE — runs locally via sentence-transformers (no AWS cost)

# App Configuration
UPLOAD_DIR=./uploads
VECTOR_STORE_DIR=./vector_stores
